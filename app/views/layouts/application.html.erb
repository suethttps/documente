<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "documente — documentação colaborativa em tempo real" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Escreva documentação com seu time, todos juntos, ao mesmo tempo. Edição em tempo real, páginas hierárquicas e exportação em Markdown.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "landing", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body class="<%= content_for(:body_class) %>">
    <%= yield %>
  </body>
</html>
