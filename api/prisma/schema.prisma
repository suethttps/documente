// Banco de dados configurável via Prisma.
// Padrão: SQLite (zero configuração). Para trocar:
//   1. mude `provider` abaixo para "postgresql" ou "mysql"
//   2. ajuste DATABASE_URL no api/.env
//   3. rode: npm run db:push
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  color     String
  password  String // hash bcrypt
  createdAt DateTime @default(now())
  pages     Page[]
}

model Page {
  id        String   @id @default(uuid())
  title     String   @default("")
  parentId  String?
  ydoc      Bytes? // snapshot CRDT (Yjs) do conteúdo
  markdown  String   @default("") // conteúdo exportado em Markdown
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId  String?
}
