# Veja https://help.github.com/articles/ignoring-files para mais sobre .gitignore

# Config sensível / por máquina
/.env*
!/.env.example

# Logs e arquivos temporários
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/.keep

# Banco SQLite local
/storage/*
!/storage/.keep
/db/*.sqlite3
/db/*.sqlite3-*

# Assets compilados
/public/assets

# Chave mestra — NUNCA commitar
/config/master.key

# Kamal
/.kamal/secrets*
